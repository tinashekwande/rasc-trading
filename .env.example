# Environment Variables for RASC Trading

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# SMTP Email Configuration
# Replace with your actual SMTP credentials
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@rasctrading.co.za
CONTACT_EMAIL=info@rasctrading.co.za

# Admin Dashboard
ADMIN_PASSWORD=rasc2024admin
ADMIN_KEY=rasc-admin-2024

# Supabase (Optional - Fallbacks to local files if not provided)
SUPABASE_URL=your-supabase-project-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=rasc-uploads
